# Build and dev files
.git
.gitignore
.vscode/
node_modules/
src/
dist/
tsconfig.json

# Generated files
*.vsix
out/**/*.map
*.js.map

# Logs and locks
npm-debug.log*
yarn-debug.log*
yarn-error.log*
yarn.lock
pnpm-lock.yaml
package-lock.json

# OS files
.DS_Store
Thumbs.db

# Claude Code (keep local)
.claude/

# Docs (only keep README and walkthroughs)
*.md
!README.md
!walkthroughs/*.md
!LICENSE

# Themes (only keep the main theme)
themes/**
!themes/terracotta-light-color-theme.json
